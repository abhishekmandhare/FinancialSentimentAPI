# Copy to .env and fill in real values — never commit .env
# docker compose uses this file automatically

# Postgres password (required)
DB_PASSWORD=changeme

# AI provider: Mock | Anthropic | Ollama | FinBert
AI_PROVIDER=Mock

# Only needed when AI_PROVIDER=Anthropic
ANTHROPIC_API_KEY=

# Only needed when AI_PROVIDER=Ollama
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3

# Only needed when AI_PROVIDER=FinBert
FINBERT_BASE_URL=
FINBERT_TIMEOUT=30

# Host ports (container ports stay fixed internally)
API_PORT=3100
PROMETHEUS_PORT=3200
GRAFANA_PORT=3300
